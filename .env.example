# Supabase — get these from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres connection string for Drizzle (use a least-privilege role)
# Find it at: Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# AI provider — choose one: anthropic | openai | gemini (default: gemini)
AI_PROVIDER=gemini

# Provider API keys — only the key for the selected AI_PROVIDER is required
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
